# UFCIM frontend — environment variables (Vite). Copy to .env and fill in.
# Only VITE_*-prefixed vars are exposed to the client bundle.

# Cloudflare Turnstile SITE key (public) used by RequestInviteView.vue to render
# the captcha on the "Solicitar Convite" page. Pairs with TURNSTILE_SECRET_KEY
# on the backend Worker. Create the widget at Cloudflare Dashboard → Turnstile;
# add hostnames "localhost" and "ufcim-front3d.pages.dev".
# Cloudflare test site key (always passes) for local dev: 1x00000000000000000000AA
VITE_TURNSTILE_SITE_KEY=
